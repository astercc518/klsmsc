# 复制为项目根目录 .env；以下为可选项示例（非密钥）
#
# ---------- Grafana（compose 默认启动 prometheus/grafana）----------
# 生产环境必须设置强口令，勿使用默认值
# GRAFANA_ADMIN_PASSWORD=请使用强口令
#
# SMPP submit_sm 等待 submit_sm_resp 最长秒数（1～120），docker-compose 会注入 worker-sms
SMPP_SUBMIT_RESP_WAIT_SECONDS=8
# 发送后保持 SMPP 连接秒数以便收 deliver_sm（60～86400）；更久必须配 HTTP report/回调
# SMPP_DLR_SOCKET_HOLD_SECONDS=300
# sent 状态最长等待终态 DLR 小时数（4～720，默认 72）；超慢通道可在后台通道上再单独设 dlr_sent_timeout_hours
# DLR_SENT_TIMEOUT_HOURS=72
# 定时拉取上游 DLR 的 HTTP 超时（秒）
# DLR_PULL_HTTP_TIMEOUT_SECONDS=60

# ---------- 通道管理「真实 SMPP bind」探测（api 调 go-smpp-gateway 内网 HTTP）----------
# 两端须设置相同随机串；未设置 SMPP_PROBE_TOKEN 时网关不启动探测端口（避免未授权 bind）
# SMPP_PROBE_TOKEN=请使用 openssl rand -hex 32
# SMPP_GATEWAY_PROBE_URL=http://smpp-gateway:8090
# SMPP_PROBE_BIND_LISTEN=:8090

# TG 业务助手「我的客户」快捷登录：须与 API、Bot 容器一致（可用 openssl rand -hex 32 生成）
# TELEGRAM_STAFF_API_SECRET=
# PUBLIC_WEB_BASE_URL=https://www.kaolach.com

# ---------- 语音模块（自建栈 / CDR Webhook；docker-compose 会注入 api、worker、beat）----------
# VOICE_PROVIDER=self_hosted
# VOICE_SIP_DOMAIN=sip.example.com
# VOICE_SIP_PORT=5060
# VOICE_SIP_TRANSPORT=udp
# VOICE_CDR_WEBHOOK_SECRET=请使用 openssl rand -hex 32
# VOICE_CDR_WEBHOOK_IP_WHITELIST=1.2.3.4,5.6.7.8
# VOICE_GATEWAY_BASE_URL=http://fs-gateway:8080
# VOICE_ORIGINATE_TOKEN=
# VOICE_CDR_WEBHOOK_IP_RATE_PER_MINUTE=300
# VOICE_CDR_MAX_RETRIES=10
# VOICE_HANGUP_SMS_MAX_PER_CALLEE_PER_DAY=20
# VOICE_MIN_BALANCE_FOR_ORIGINATE=0
# VOS 管理 Web 根地址（语音路由页探测用），例：http://IP:9292
# VOS_HTTP_BASE=
# VOS_HTTP_USERNAME=
# VOS_HTTP_PASSWORD=
# VOS_HTTP_VERIFY_SSL=true
