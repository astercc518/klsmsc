# ======================================
# SMSC 国际短信网关 - 环境变量模板
# 复制此文件为 .env 并填入实际值
# ======================================

# --- 应用配置 ---
APP_ENV=development
APP_DEBUG=true

# --- CORS（生产环境必须配置具体域名，多个用逗号分隔） ---
# CORS_ORIGINS=https://admin.example.com,https://www.example.com

# --- MySQL（docker-compose 和后端共用） ---
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=sms_system
MYSQL_USER=smsuser
MYSQL_PASSWORD=changeme

# --- 本地开发时后端直连数据库 ---
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=smsuser
DATABASE_PASSWORD=changeme
DATABASE_NAME=sms_system

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- JWT（生产环境必须设置高强度密钥） ---
# 可使用 python -c "import secrets; print(secrets.token_urlsafe(48))" 生成
JWT_SECRET_KEY=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_GROUP_ID=

# --- API 限流 ---
RATE_LIMIT_PER_MINUTE=1000

# --- 日志 ---
LOG_LEVEL=INFO
